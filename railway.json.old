{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"],
      "phases": {
        "setup": {
          "nixPkgs": ["python314", "gcc"]
        },
        "install": {
          "cmds": ["pip install --no-cache-dir -r requirements.txt"]
        },
        "start": {
          "cmd": "python mybot.py"
        }
      }
    }
  }
}